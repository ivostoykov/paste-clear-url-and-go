{
  "manifest_version": 3,
  "name": "Paste Clear URL And Go",
  "version": "1.1.11",
  "description": "Strip tracking params from a clipboard URL and open it in current, new, or private tab.",
  "background": { "scripts": ["background.js"] },
  "permissions": ["clipboardRead", "storage", "tabs", "windows", "contextMenus"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true,
    "browser_style": false
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "paste-clear-url-and-go@extension",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
